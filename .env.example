# Environment mode (development, test, production).
# Controls which TOML config overlay is applied.
STORYTELLER_ENV=development

# Path to the merged TOML config file.
# Generated by `cargo make setup-env` or `cargo-make/scripts/setup-env.sh`.
STORYTELLER_CONFIG_PATH=config/storyteller/generated/storyteller-development.toml

# Path to the storyteller-data repository (private content, training data, etc.)
# This is required for training data generation and any tools that reference
# authored content. Set this to the absolute path of your storyteller-data checkout.
STORYTELLER_DATA_PATH=/path/to/storyteller-data

# Path to trained model artifacts (.onnx files).
# Defaults to $STORYTELLER_DATA_PATH/models if not set.
# The character prediction model is expected at $STORYTELLER_MODEL_PATH/character_predictor.onnx
STORYTELLER_MODEL_PATH=/path/to/storyteller-data/models

# PostgreSQL connection URL for sqlx.
# Default connects to the Docker Compose dev database (port 5435).
DATABASE_URL=postgres://storyteller:storyteller@localhost:5435/storyteller_development

# ------------------------------------------------------------------
# Engine Server (storyteller-server)
# ------------------------------------------------------------------

# gRPC port for the storyteller-server (default: 50051).
STORYTELLER_GRPC_PORT=50051

# Ollama server URL (default: http://localhost:11434).
OLLAMA_URL=http://localhost:11434

# LLM model names for each agent role.
STORYTELLER_NARRATOR_MODEL=qwen2.5:14b
STORYTELLER_DECOMPOSITION_MODEL=qwen2.5:3b-instruct
STORYTELLER_INTENT_MODEL=qwen2.5:3b-instruct

# Session persistence directory (default: .story/sessions).
STORYTELLER_SESSIONS_DIR=.story/sessions

# ------------------------------------------------------------------
# Client (storyteller-client / storyteller-cli / storyteller-workshop)
# ------------------------------------------------------------------

# gRPC server URL for the client to connect to (default: http://localhost:50051).
# The workshop requires a running server: cargo run -p storyteller-server
STORYTELLER_SERVER_URL=http://localhost:50051

# Ollama model for the simulated player in `storyteller-cli playtest`.
STORYTELLER_PLAYER_MODEL=qwen2.5:7b-instruct
